# Copy this file to .env.local and fill with your Supabase project values.
# Find them in Supabase Dashboard → Project Settings → API.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. Needed for the Users tab (inviting / deleting users).
# Never expose this in NEXT_PUBLIC_*. Add it in Vercel → Project → Settings → Environment Variables.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key
